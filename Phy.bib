@article{Heilman2008,
	abstract = {A critical examination of research on the rela- tionship between stereotyping and workplace discrimination must meet three requirements. The first requirement is an understanding of the theory that guides this research. The second requirement is an unbiased review of relevant research. The third requirement is comprehension of the ways that different types of research are informative about behavior in organizations. Landy (2008) meets none of these requirements. He misstates the consensual social scientific theory about the relation between stereotyp- ing and discrimination, presents only a selective portion of the relevant research, and misconstrues the basis for generalizing research findings to organizations. As a result, Landy misrepresents the evidence for stereo- type-based workplace discrimination. For brevity, we consider only sex discrimination. Also, consistent with Landy's emphasis, we address the consequences of stereotypes that describe women and men as opposed to stereotypes that prescribe normatively acceptable behavior for them and thus sanction behavior deviating from gender norms (see Eagly {\&} Karau, 2002; Heilman, 2001).},
	author = {Heilman, Madeline and Eagly, Alice},
	date-added = {2026-04-23 12:58:56 +0300},
	date-modified = {2026-04-23 12:58:56 +0300},
	doi = {10.1111/j.1754-9434.2008.00072.x},
	file = {:Users/hectorbahamonde/Documents/Mendeley Desktop/Heilman, Eagly/Industrial and Organizational Psychology/Heilman, Eagly - 2008 - Gender Stereotypes Are Alive, Well, and Busy Producing Workplace Discrimination.pdf:pdf},
	issn = {1754-9426},
	journal = {Industrial and Organizational Psychology},
	month = {dec},
	number = {4},
	pages = {393--398},
	title = {{Gender Stereotypes Are Alive, Well, and Busy Producing Workplace Discrimination}},
	url = {https://www.cambridge.org/core/product/identifier/S1754942600000729/type/journal{\_}article},
	volume = {1},
	year = {2008},
	bdsk-url-1 = {https://www.cambridge.org/core/product/identifier/S1754942600000729/type/journal%7B%5C_%7Darticle},
	bdsk-url-2 = {https://doi.org/10.1111/j.1754-9434.2008.00072.x}}

@article{Budesheim1994,
	abstract = {Two studies investigated the effects of image and issue information on evaluations of political candidates. The extent to which voters base their evaluations on stereotypic image information (i.e., candidates' physical attractiveness) and nonstereotypic image information (i.e., individuating personality descriptions of the candidates) was examined. Also of interest were the factors that lead to image-based, as opposed to issue-based, evaluations of the candidates. Results demonstrated that (a) physical appearance influenced evaluations even when individuating personality information was provided, (b) subjects' evaluations were less influenced by their agreement with the candidates' issue positions when image information was presented than when it was not, and (c) subjects' evaluations were less influenced by issue agreement when a candidate's image was evaluatively mixed than when it was evaluatively consistent.},
	author = {Budesheim, Thomas and DePaola, Stephen},
	date-added = {2026-04-23 12:56:42 +0300},
	date-modified = {2026-04-23 12:56:42 +0300},
	doi = {10.1177/0146167294204001},
	file = {:Users/hectorbahamonde/Documents/Mendeley Desktop/Budesheim, DePaola/Personality and Social Psychology Bulletin/Budesheim, DePaola - 1994 - Beauty or the Beast The Effects of Appearance, Personality, and Issue Information on Evaluations of Politica.pdf:pdf},
	issn = {0146-1672},
	journal = {Personality and Social Psychology Bulletin},
	month = {aug},
	number = {4},
	pages = {339--348},
	title = {{Beauty or the Beast? The Effects of Appearance, Personality, and Issue Information on Evaluations of Political Candidates}},
	url = {http://journals.sagepub.com/doi/10.1177/0146167294204001},
	volume = {20},
