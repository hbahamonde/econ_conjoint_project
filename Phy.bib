@article{Berggren2017,
	abstract = {Since good-looking politicians win more votes, a beauty advantage for politicians on the left or on the right is bound to have political consequences. We show that politicians on the right look more beautiful in Europe, the United States and Australia. Our explanation is that beautiful people earn more, which makes them less inclined to support redistribution. Our model of within-party competition predicts that voters use beauty as a cue for conservatism when they do not know much about candidates and that politicians on the right benefit more from beauty in low-information elections. Evidence from real and experimental elections confirms both predictions.},
	annote = {{\#} voters use beauty as a cue for con- servatism when they do not know much about candidates

{\#} beautiful people earn more (Hamermesh and Biddle, 1994; Scholz and Sicinski, 2015)

{\#} The general pattern that politicians on the right look better than pol-
iticians on the left implies that beauty can be used as a cue for ideology in low-information elections.

{\#} We show that in municipal elections, a beauty increase of one standard deviation attracts about 20{\%} more votes for the average non-incumbent candidate on the right and about 8{\%} more votes for the average non-incumbent candidate on the left.

{\#} A more general psychological expla- nation could be that good-looking people are more likely to perceive the world as a just place, since they are treated better than others (Langlois et al. 2000), achieve higher status (Anderson et al. 2001) and are happier (Hamermesh andAbrevaya, 2013) --},
	author = {Berggren, Niclas and Jordahl, Henrik and Poutvaara, Panu},
	date-added = {2026-04-23 12:54:24 +0300},
	date-modified = {2026-04-23 12:54:24 +0300},
	doi = {10.1016/j.jpubeco.2016.12.008},
	file = {:Users/hectorbahamonde/Documents/Mendeley Desktop/Berggren, Jordahl, Poutvaara/Journal of Public Economics/Berggren, Jordahl, Poutvaara - 2017 - The Right Look Conservative Politicians Look Better and Voters Reward It.pdf:pdf},
	issn = {00472727},
	journal = {Journal of Public Economics},
	keywords = {Appearance,Beauty,Elections,Ideology,Parties,Political candidates},
	month = {feb},
	number = {5383},
	pages = {79--86},
	title = {{The Right Look: Conservative Politicians Look Better and Voters Reward It}},
	url = {http://dx.doi.org/10.1016/j.jpubeco.2016.12.008 https://linkinghub.elsevier.com/retrieve/pii/S0047272716302201},
	volume = {146},
	year = {2017},
	bdsk-url-1 = {http://dx.doi.org/10.1016/j.jpubeco.2016.12.008%20https://linkinghub.elsevier.com/retrieve/pii/S0047272716302201},
	bdsk-url-2 = {http://dx.doi.org/10.1016/j.jpubeco.2016.12.008}}

@article{Wigginton2021,
	abstract = {The literature on looks and politics suggests that, at least in personalistic electoral systems, physical attractiveness helps candidates that are more attractive. We test this assumption using the unlikely case of Quebec, where provincial elections are highly salient, characterized by a strong cleavage, a sophisticated electorate and strong party- and leader-centeredness. Evaluating the effect of physical attractiveness on vote shares for nearly 5500 candidates in a multivariate analysis for four elections (i.e. 2008, 2012, 2014 and 2018), we find that physical attractiveness plays no role in determining candidates' vote shares. This applies for candidates' attractiveness score, as well as their attractiveness ranking relative to other candidates. For theory, this finding suggests that the effect of attractiveness on candidates' electoral fortunes in winner takes all systems is contingent on other factors such as the existence of cleavages and the candidate- or party centeredness of the party system.},
	author = {Wigginton, Michael and Stockemer, Daniel},
	date-added = {2026-04-23 12:54:10 +0300},
	date-modified = {2026-04-23 12:54:10 +0300},
	doi = {10.1016/j.electstud.2020.102274},
	file = {:Users/hectorbahamonde/Downloads/1-s2.0-S0261379420301529-main.pdf:pdf},
	issn = {02613794},
	journal = {Electoral Studies},
	keywords = {Elections,Physical attractiveness,Quebec,Votes},
	month = {apr},
	number = {December 2020},
	pages = {102274},
	publisher = {Elsevier Ltd},
	title = {{The Limits of the Attractiveness Premium in Elections}},
	url = {https://doi.org/10.1016/j.electstud.2020.102274 https://linkinghub.elsevier.com/retrieve/pii/S0261379420301529},
	volume = {70},
	year = {2021},
	bdsk-url-1 = {https://doi.org/10.1016/j.electstud.2020.102274%20https://linkinghub.elsevier.com/retrieve/pii/S0261379420301529},
	bdsk-url-2 = {https://doi.org/10.1016/j.electstud.2020.102274}}

@article{Berggren2010,
	abstract = {We study the role of beauty in politics using candidate photos that figured prominently in electoral campaigns. Our investigation is based on visual assessments of 1929 Finnish political candidates from 10,011 respondents (of which 3708 were Finnish). As Finland has a proportional electoral system, we are able to compare the electoral success of non-incumbent candidates representing the same party. An increase in our measure of beauty by one standard deviation is associated with an increase of 20{\%} in the number of votes for the average non-incumbent parliamentary candidate. The relationship is unaffected by including education and occupation as control variables and withstands several other robustness checks. {\textcopyright} 2009 Elsevier B.V. All rights reserved.},
