	journal = {Political Psychology},
	keywords = {attractiveness,competence,face perception,face-based inference,halo effect,ideology},
	month = {jun},
	number = {3},
	pages = {401--417},
	title = {{Attractiveness and Facial Competence Bias Face-Based Inferences of Candidate Ideology}},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/pops.12256},
