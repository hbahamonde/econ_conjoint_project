	issn = {0304-4130},
	journal = {European Journal of Political Research},
	month = {sep},
	number = {1},
	pages = {64--79},
	title = {{The Frog Pond Beauty Contest: Physical Attractiveness and Electoral Success of the Constituency Candidates at the North Rhine-Westphalia State Election of 2005}},
