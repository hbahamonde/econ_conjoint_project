	issn = {1939-1854},
	journal = {Journal of Applied Psychology},
	number = {3},
	pages = {416--427},
	pmid = {15161402},
	title = {{Penalties for Success: Reactions to Women Who Succeed at Male Gender-Typed Tasks}},
