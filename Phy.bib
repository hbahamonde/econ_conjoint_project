	file = {:Users/hectorbahamonde/Documents/Mendeley Desktop/Banducci et al/Political Psychology/Banducci et al. - 2008 - Ballot Photographs as Cues in Low-Information Elections.pdf:pdf},
	issn = {0162895X},
	journal = {Political Psychology},
	keywords = {Ballot photographs,Candidate appearance,First impressions,Heuristics,Low-information elections},
	month = {oct},
	number = {6},
	pages = {903--917},
	title = {{Ballot Photographs as Cues in Low-Information Elections}},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/j.1467-9221.2008.00672.x},
